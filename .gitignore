# Local-only files containing real subscription / tenant / account identifiers
# kept on disk for testing but never committed.
*.local.json
*.local.yaml
*.local.yml
*.local.toml

# Editor / interpreter cruft
.Rhistory
.DS_Store

# Office lock files
~$*

# Reference assessment spreadsheets (input data, not deliverable)
*.xlsx

# ATO package staging directory — transient scratch space the orchestrator
# wipes at end-of-run (citation batches, doc-summarizer manifests + excerpts,
# vulnscan tool output). Never part of the deliverable.
docs/ato-package/.staging/

# Local git worktree scratch space — agents (and the adversarial-review
# MCP server) sometimes drop worktrees here for isolated runs.
.worktrees/
